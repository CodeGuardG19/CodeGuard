# CodeGuard Infrastructure Configuration
# Source this file in all infra scripts: source "$(dirname "$0")/config.env"
#
# BEFORE DEPLOYING — set these three values:
#   AWS_ACCOUNT_ID   : your 12-digit AWS account number
#   NOTIFICATION_EMAIL: email address for SNS security alerts
#   Then pre-create SSM parameters (see deploy.sh for instructions)

# ── AWS Core ──────────────────────────────────────────────────────────────────
export AWS_REGION="us-east-1"
export AWS_ACCOUNT_ID="YOUR_ACCOUNT_ID"          # ← replace before deploying

# ── Networking ────────────────────────────────────────────────────────────────
export VPC_CIDR="10.0.0.0/16"
export PUBLIC_SUBNET_CIDR="10.0.1.0/24"
export PRIVATE_SUBNET_CIDR="10.0.2.0/24"
export AVAILABILITY_ZONE="${AWS_REGION}a"

# ── EC2 ───────────────────────────────────────────────────────────────────────
export EC2_INSTANCE_TYPE="t3.micro"
export EC2_AMI_SSM_PATH="/aws/service/ami-amazon-linux-latest/al2023-ami-kernel-6.1-x86_64"

# ── IAM (Lab environment) ──────────────────────────────────────────────────────
# LabRole and LabInstanceProfile are pre-provisioned by the course environment.
export LAB_ROLE_ARN="arn:aws:iam::${AWS_ACCOUNT_ID}:role/LabRole"
export LAB_INSTANCE_PROFILE="LabInstanceProfile"

# ── Lambda — shared ───────────────────────────────────────────────────────────
export LAMBDA_MEMORY="512"
export WEBHOOK_LAMBDA_TIMEOUT="30"
export SCANNER_LAMBDA_TIMEOUT="300"
export NOTIFIER_LAMBDA_TIMEOUT="30"

# ── Lambda — function names ───────────────────────────────────────────────────
export WEBHOOK_LAMBDA_NAME="codeguard-webhook-handler"
export SAST_LAMBDA_NAME="codeguard-sast-scanner"
export NOTIFIER_LAMBDA_NAME="codeguard-notifier"

# ── ECR ───────────────────────────────────────────────────────────────────────
export WEBHOOK_ECR_REPO="codeguard-webhook-handler"
export SCANNER_ECR_REPO="codeguard-sast-scanner"

# ── S3 (single shared bucket for all three Lambdas) ───────────────────────────
export S3_BUCKET_NAME="codeguard-reports-${AWS_ACCOUNT_ID}"

# ── SNS ───────────────────────────────────────────────────────────────────────
export SNS_TOPIC_NAME="codeguard-alerts"
export NOTIFICATION_EMAIL="YOUR_EMAIL@example.com"  # ← replace before deploying

# ── SSM Parameter Store ───────────────────────────────────────────────────────
# Both parameters must be pre-created before running deploy.sh (see instructions there).
export WEBHOOK_SECRET_PARAM="/codeguard/github-webhook-secret"
export GITHUB_TOKEN_PARAM="/codeguard/github-token"

# ── Tagging ───────────────────────────────────────────────────────────────────
export PROJECT_TAG="codeguard"
