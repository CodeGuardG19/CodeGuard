# CodeGuard Infrastructure Configuration
# Source this file in all infra scripts: source "$(dirname "$0")/config.env"
# Never commit real account IDs or secrets — replace placeholders before deploying.

# ── AWS Core ──────────────────────────────────────────────────────────────────
export AWS_REGION="us-east-1"
export AWS_ACCOUNT_ID="613914990679"

# ── Networking ────────────────────────────────────────────────────────────────
export VPC_CIDR="10.0.0.0/16"
export PUBLIC_SUBNET_CIDR="10.0.1.0/24"
export PRIVATE_SUBNET_CIDR="10.0.2.0/24"
export AVAILABILITY_ZONE="${AWS_REGION}a"

# ── EC2 ───────────────────────────────────────────────────────────────────────
# t3.micro: free-tier eligible (750 hrs/month), better network burst than t2.micro
export EC2_INSTANCE_TYPE="t3.micro"
# Amazon Linux 2023 kernel 6.1 — resolved dynamically in 03-ec2.sh via SSM
# SSM path: /aws/service/ami-amazon-linux-latest/al2023-ami-kernel-6.1-x86_64
export EC2_AMI_SSM_PATH="/aws/service/ami-amazon-linux-latest/al2023-ami-kernel-6.1-x86_64"

# ── IAM (Lab environment) ──────────────────────────────────────────────────────
# LabRole and LabInstanceProfile are pre-provisioned by the course environment.
# 02-security.sh does NOT create these — it only creates security groups.
export LAB_ROLE_ARN="arn:aws:iam::${AWS_ACCOUNT_ID}:role/LabRole"
export LAB_INSTANCE_PROFILE="LabInstanceProfile"

# ── Lambda ────────────────────────────────────────────────────────────────────
export LAMBDA_MEMORY="512"
export LAMBDA_TIMEOUT="30"
export WEBHOOK_LAMBDA_NAME="codeguard-webhook-handler"
export SAST_LAMBDA_NAME="codeguard-sast-scanner"   # Person B's function name

# ── ECR ───────────────────────────────────────────────────────────────────────
export ECR_REPO_NAME="codeguard-webhook-handler"

# ── S3 ────────────────────────────────────────────────────────────────────────
export S3_BUCKET_NAME="codeguard-jobs-${AWS_ACCOUNT_ID}"

# ── SNS ───────────────────────────────────────────────────────────────────────
export SNS_TOPIC_NAME="codeguard-scan-alerts"

# ── SSM Parameter Store ───────────────────────────────────────────────────────
export WEBHOOK_SECRET_PARAM="/codeguard/github-webhook-secret"

# ── Tagging ───────────────────────────────────────────────────────────────────
export PROJECT_TAG="codeguard"
export OWNER_TAG="person-a"
